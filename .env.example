# Select ollama or openai.
ASSISTANT_AI_PROVIDER=ollama

# Ollama defaults.
ASSISTANT_AI_OLLAMA_BASE_URL=http://localhost:11434
ASSISTANT_AI_OLLAMA_MODEL=qwen3:8b

# Replace this placeholder only when using OpenAI.
OPENAI_API_KEY=replace-with-your-openai-api-key
ASSISTANT_AI_OPENAI_MODEL=gpt-5.4-mini

# Schema and logging.
ASSISTANT_SCHEMA_LOCATION=classpath:schema.graphql
ASSISTANT_LOGGING_FULL_CONTENT_ENABLED=false
